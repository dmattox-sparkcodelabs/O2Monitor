<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
    Allow cleartext (HTTP) for local/private network addresses.
    This app only communicates with the Pi on local network or VPN.
    No public internet servers are accessed.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
